        }

        .reading-mode {
            max-width: 800px;
            margin: 0 auto;
            background: #f8fafc;
        }

        .progress-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            z-index: 1000;
        }

        #progress-bar {
            height: 100%;
            background: #3b82f6;
